OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=hf.co/TeichAI/Qwen3-14B-Claude-4.5-Opus-High-Reasoning-Distill-GGUF:Q4_K_M
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
OLLAMA_MAX_RETRIES=1
OLLAMA_RETRY_BACKOFF_SECONDS=0.75
AMIAGI_SUPERVISOR_ENABLED=true
AMIAGI_SUPERVISOR_MODEL=cogito:14b
AMIAGI_SUPERVISOR_MAX_REPAIR_ROUNDS=2
AMIAGI_SUPERVISOR_REQUEST_TIMEOUT_SECONDS=120
AMIAGI_SUPERVISOR_MIN_FREE_VRAM_MB=3000
AMIAGI_MODEL_QUEUE_MAX_WAIT_SECONDS=1.0
AMIAGI_AUTONOMOUS_MODE=true
AMIAGI_MAX_IDLE_AUTOREACTIVATIONS=2
AMIAGI_DB_PATH=./data/amiagi.db
AMIAGI_MODEL_IO_LOG_PATH=./logs/model_io.jsonl
AMIAGI_EXECUTOR_MODEL_IO_LOG_PATH=./logs/model_io_executor.jsonl
AMIAGI_SUPERVISOR_MODEL_IO_LOG_PATH=./logs/model_io_supervisor.jsonl
AMIAGI_SUPERVISOR_DIALOGUE_LOG_PATH=./logs/supervision_dialogue.jsonl
AMIAGI_ACTIVITY_LOG_PATH=./logs/activity.jsonl
AMIAGI_SHELL_POLICY_PATH=./config/shell_allowlist.json
AMIAGI_WORK_DIR=./amiagi-my-work
AMIAGI_MAX_CONTEXT_MEMORIES=5

# ── OAuth 2.0 (Google) ─────────────────────────────────────
# Typ aplikacji: Aplikacja internetowa
# Autoryzowane źródła JS: http://localhost:8080, http://localhost:8090
# Autoryzowane URI przekierowania: http://localhost:8080/auth/callback
AMIAGI_OAUTH_CLIENT_ID=
AMIAGI_OAUTH_CLIENT_SECRET=
AMIAGI_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
AMIAGI_OAUTH_SCOPES=openid email profile
AMIAGI_OAUTH_PROVIDER=google

# ── PostgreSQL (schemat dbo) ────────────────────────────────
# Baza danych dla Web GUI: użytkownicy, sesje, RBAC, skills, audyt
AMIAGI_DB_HOST=localhost
AMIAGI_DB_PORT=5432
AMIAGI_DB_NAME=amiagi
AMIAGI_DB_SCHEMA=dbo
AMIAGI_DB_USER=
AMIAGI_DB_PASSWORD=
AMIAGI_DB_MIN_POOL=2
AMIAGI_DB_MAX_POOL=10

# ── Audit & Workspace ──────────────────────────────────────────
AMIAGI_AUDIT_RETENTION_DAYS=90
AMIAGI_WORKSPACE_MAX_SIZE_MB=500
AMIAGI_WORKSPACE_BASE_DIR=./data/workspaces
